# =============================================================================
# Veterinary Clinic API — environment template
# Copy to `.env` and replace placeholder values. Never commit `.env`.
#
#   cp .env.example .env
#
# Connection strings (local, Docker, AWS RDS, ElastiCache, etc.) — set URLs only.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose profile
# -----------------------------------------------------------------------------
# `default` = just the API (standalone, uses the URLs below as-is).
# Override on the CLI for the bundled stack: docker compose --profile full up
COMPOSE_PROFILES=default

# -----------------------------------------------------------------------------
# PostgreSQL — endpoint URL + credentials (jdbc: prefix is optional)
# -----------------------------------------------------------------------------
# Credentials are used by go run and the `default` profile. The `full` profile
# also uses them to provision and connect to the bundled postgres service.
DATABASE_USER=postgres
DATABASE_PASSWORD=change_me_secure_password
DATABASE_NAME=vet_database

# Endpoint for go run / tools on your machine (host port 5431 when using local Docker)
DATABASE_URL=postgresql://localhost:5431/vet_database?sslmode=disable

# AWS RDS example (sslmode=require is added automatically for *.rds.amazonaws.com):
# DATABASE_URL=jdbc:postgresql://my-db.xxxx.us-east-1.rds.amazonaws.com:5432/vet_database
# DATABASE_USER=postgres
# DATABASE_PASSWORD=change_me

# Optional connection pool tuning
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=1h
DATABASE_CONN_MAX_IDLE_TIME=30m

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Password for the bundled redis service (full profile).
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# Namespace for all keys on shared Redis (avoids clashes with other projects)
REDIS_KEY_PREFIX=vet-clinic-api

# URL used as-is by the `default` profile (cloud / Upstash / ElastiCache).
REDIS_URL=redis://:change_me_redis_password@localhost:6379/0
# REDIS_URL=rediss://:password@my-redis.xxxx.cache.amazonaws.com:6379/0

# Optional: host ports published by the `full` profile (default 5431 / 6379)
POSTGRES_PUBLISHED_PORT=5431
REDIS_PUBLISHED_PORT=6379

# -----------------------------------------------------------------------------
# Migrations on startup
# -----------------------------------------------------------------------------
# The `full` profile forces these to false (fresh DB needs migrating). For the
# `default` profile against a managed DB, skipping is usually what you want.
SKIP_MIGRATIONS=true
SKIP_DB_WAIT=true

# -----------------------------------------------------------------------------
# Authentication
# JWT_SECRET must be at least 32 characters
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_random_string_at_least_32_characters_long
JWT_EXPIRATION_TIME=24h
REFRESH_TOKEN_EXPIRY=168h
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30m

# -----------------------------------------------------------------------------
# Twilio SMS
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@example.com
FROM_NAME="Vet Clinic System"
PROJECT_NAME="Veterinary Clinic Management System"
LOGO_URL=https://example.com/logo.png

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
ENVIRONMENT=development
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
ENABLE_HTTPS=false
CERT_FILE=./certs/cert.pem
KEY_FILE=./certs/key.pem

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Clinic Vet API"
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=info
ENABLE_SWAGGER=true

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=12h

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=99
RATE_LIMIT_WINDOW=0m
RATE_LIMIT_BURST=19
